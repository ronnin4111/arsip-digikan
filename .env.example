# Database - Neon Postgres (via Vercel Integration)
# These are automatically set when you connect a Neon Postgres store in Vercel
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://user:password@host/database?sslmode=require"

# Vercel Blob Store (fallback, if Google Drive not configured)
# Automatically set when you connect a Blob store in Vercel
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxx"

# JWT Secret (generate a secure random string)
JWT_SECRET="your-secure-jwt-secret-here"

# Google Drive Integration (RECOMMENDED for larger storage)
# 1. Go to https://console.cloud.google.com
# 2. Create a project → Enable Google Drive API
# 3. Create Service Account → Download JSON key
# 4. Share a Google Drive folder with the service account email
# 5. Copy the folder ID from the URL: https://drive.google.com/drive/folders/FOLDER_ID_HERE
GOOGLE_SERVICE_ACCOUNT_EMAIL="your-service-account@your-project.iam.gserviceaccount.com"
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_DRIVE_FOLDER_ID="your-google-drive-folder-id"

# Node environment
NODE_ENV="production"
